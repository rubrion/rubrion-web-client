# Cloudflare Worker that handles contact form submissions.
# Local dev: `wrangler dev` inside support-email-worker/ exposes http://localhost:8787/submit
# Production: your deployed worker URL with the /submit path
VITE_SUPPORT_WORKER_URL=https://support.rubrion.workers.dev/submit

# Cloudflare Turnstile site key (paired with TURNSTILE_SECRET_KEY in the worker).
# Leave empty to disable the captcha widget on the frontend.
VITE_TURNSTILE_SITE_KEY=
