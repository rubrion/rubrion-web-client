---
import { Cpu, ExternalLink, Github, Newspaper, Store } from 'lucide-react';

import { PROJECTS } from '@/data/projects';

const ICONS = { Newspaper, Store, Cpu } as const;
---
<section
  id="projects"
  class="lazy-paint py-20 px-4 relative z-20 bg-surface-raised overflow-hidden"
>
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-6">Projetos</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {PROJECTS.map((project) => {
        const Icon = ICONS[project.iconName];
        return (
          <article
            class="bg-surface-base border border-border-default rounded-xl p-6 hover:border-primary/60 transition-all duration-300 group flex flex-col"
          >
            <div class="flex items-start justify-between mb-4">
              <div
                class="w-10 h-10 bg-surface-raised border border-primary/40 rounded-lg flex items-center justify-center"
              >
                <Icon className="w-5 h-5 text-primary" strokeWidth={1.5} />
              </div>
              {project.isSister && (
                <span
                  class="font-mono text-[10px] uppercase tracking-wider text-accent-indigo border border-accent-indigo/50 px-2 py-1 rounded"
                  aria-label="Projeto irmão"
                >
                  Projeto irmão
                </span>
              )}
            </div>

            <span class="font-mono text-xs text-primary mb-2">{project.category}</span>
            <h3
              class="text-2xl font-bold font-mono text-text-primary mb-3 group-hover:text-accent-indigo transition-colors"
            >
              {project.title}
            </h3>
            <p class="text-text-secondary mb-5 flex-grow">{project.description}</p>

            <ul class="flex flex-wrap gap-2 mb-6" aria-label="Tags">
              {project.tags.map((tag) => (
                <li
                  class="font-mono text-[11px] text-text-muted bg-surface-raised border border-border-default rounded px-2 py-1"
                >
                  {tag}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-3 mt-auto">
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-transparent text-primary border border-primary px-4 py-2 rounded font-mono text-sm hover:bg-primary hover:text-surface-base transition-all duration-200"
              >
                <ExternalLink className="w-4 h-4" strokeWidth={2} />
                &gt;visitar_site
              </a>
              {project.repoUrl && (
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-text-muted hover:text-text-primary px-4 py-2 rounded font-mono text-sm transition-colors"
                >
                  <Github className="w-4 h-4" strokeWidth={2} />
                  &gt;ver_codigo
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
